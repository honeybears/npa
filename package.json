{
  "name": "@honeybeaers/node-persistence-api-core",
  "version": "0.1.0",
  "description": "Core Node and TypeScript persistence API with generated repository clients",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "npa": "dist/cli/npa.js"
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf dist packages/pg/dist packages/mysql/dist",
    "build": "tsc -p tsconfig.json && tsc -p packages/pg/tsconfig.json && tsc -p packages/mysql/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run clean && npm run build && node --test test/*.test.js",
    "test:e2e": "npm run clean && npm run build && node --test test/e2e/*.test.js",
    "prepack": "npm run clean && npm run build"
  },
  "keywords": [
    "node",
    "typescript",
    "persistence",
    "repository",
    "orm"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testcontainers/mysql": "^12.0.3",
    "@testcontainers/postgresql": "^12.0.3",
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.0"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4"
}
