{
  "name": "@node-persistence-api/core",
  "version": "0.1.0-beta.3",
  "description": "Core Node and TypeScript persistence API with JPA-style repositories",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./query-method": {
      "types": "./dist/query-method/index.d.ts",
      "require": "./dist/query-method/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter/index.d.ts",
      "require": "./dist/adapter/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "npa": "dist/cli/npa.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "clean": "rm -rf dist packages/*/dist examples/*/dist",
    "build": "tsc -p tsconfig.json && tsc -p packages/language/tsconfig.json && tsc -p packages/pg/tsconfig.json && tsc -p packages/mysql/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run clean && npm run build && npm run typecheck:test && NODE_OPTIONS=--experimental-vm-modules jest --runInBand --testPathIgnorePatterns /test/e2e/",
    "test:e2e": "npm run clean && npm run build && NODE_OPTIONS=--experimental-vm-modules jest --runInBand test/e2e",
    "prepack": "npm run clean && npm run build",
    "test:packages": "npm run clean && npm run build && NODE_OPTIONS=--experimental-vm-modules jest --runInBand packages",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test:vscode": "pnpm --dir packages/vscode test:host",
    "bench": "pnpm build && node benchmarks/benchmark.js",
    "bench:json": "pnpm build && node benchmarks/benchmark.js --json",
    "bench:live": "pnpm build && node benchmarks/benchmark.js --live",
    "package:vscode": "pnpm --dir packages/vscode package:vsix",
    "package:vscode:pre": "pnpm --dir packages/vscode package:vsix:pre",
    "publish:vscode": "pnpm --dir packages/vscode publish:marketplace",
    "publish:vscode:pre": "pnpm --dir packages/vscode publish:marketplace:pre",
    "verify:vscode-pat": "pnpm --dir packages/vscode verify:pat",
    "verify:vscode-install": "pnpm --dir packages/vscode verify:install",
    "bench:compare": "pnpm build && node benchmarks/compare/compare.js",
    "release:pack": "rm -rf .release && mkdir -p .release && pnpm pack --pack-destination .release && pnpm --dir packages/language pack --pack-destination ../../.release && pnpm --dir packages/pg pack --pack-destination ../../.release && pnpm --dir packages/mysql pack --pack-destination ../../.release",
    "release:inspect": "node scripts/inspect-release.mjs"
  },
  "keywords": [
    "node",
    "typescript",
    "persistence",
    "repository",
    "orm"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@testcontainers/mysql": "^12.0.4",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "pnpm": "^10.30.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4"
}
