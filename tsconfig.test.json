{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "isolatedModules": true,
    "noImplicitAny": false,
    "noEmit": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": false,
    "types": ["node", "jest"]
  },
  "include": [
    "test/**/*.ts",
    "packages/*/test/*.ts"
  ]
}
