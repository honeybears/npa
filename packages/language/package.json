{
  "name": "@node-persistence-api/language",
  "version": "0.1.0",
  "description": "Editor-independent language helpers for Node Persistence API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "cd ../.. && npm run build",
    "test": "cd ../.. && npm run build && node --test packages/language/test/*.test.js"
  },
  "dependencies": {
    "@node-persistence-api/core": "workspace:^"
  },
  "license": "MIT"
}
