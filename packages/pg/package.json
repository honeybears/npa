{
  "name": "@node-persistence-api/connector-pg",
  "version": "0.1.0",
  "description": "PostgreSQL connector for Node Persistence API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "cd ../.. && npm run build",
    "test": "cd ../.. && npm run build && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand packages/pg/test"
  },
  "dependencies": {
    "@node-persistence-api/core": "workspace:^",
    "pg": "^8.22.0"
  },
  "license": "MIT"
}
