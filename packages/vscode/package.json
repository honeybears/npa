{
  "name": "npa",
  "displayName": "NPA",
  "description": "VS Code completion and diagnostics for Node Persistence API repositories",
  "version": "0.1.0",
  "publisher": "honeybeaers",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./src/extension.js",
  "files": [
    "src",
    "vendor",
    "package.json",
    "README.md",
    "LICENSE.txt"
  ],
  "scripts": {
    "build": "node scripts/prepare-vsix.js",
    "test": "pnpm run test:core",
    "test:core": "cd ../.. && npm run build && node --test packages/vscode/test/*.test.js",
    "test:host": "cd ../.. && npm run build && pnpm --dir packages/vscode run build && node packages/vscode/test/run-extension-host.js",
    "package:vsix": "node scripts/package-vsix.js",
    "package:vsix:pre": "node scripts/package-vsix.js --pre-release",
    "publish:marketplace": "node scripts/publish-marketplace.js",
    "publish:marketplace:pre": "node scripts/publish-marketplace.js --pre-release",
    "verify:pat": "pnpm exec vsce verify-pat honeybeaers",
    "verify:install": "node scripts/verify-install.js",
    "package:check": "pnpm run package:vsix && pnpm run verify:install"
  },
  "devDependencies": {
    "@node-persistence-api/language": "workspace:^",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/honeybears/npa.git",
    "directory": "packages/vscode"
  }
}
